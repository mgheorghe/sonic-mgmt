    chip "xdpe12284-i2c-*-66"
        label in1 "PMIC-3 12V ASIC VDD_T0_T3 VDDI_T0_T3 (in1)"
        label in2 "PMIC-3 12V ASIC VDD_T0_T3 VDDI_T0_T3 (in2)"
