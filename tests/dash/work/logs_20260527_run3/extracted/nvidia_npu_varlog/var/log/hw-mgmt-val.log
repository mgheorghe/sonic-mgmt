        label in1 "PMIC-2 12V ASIC VDDI_M VDDHS_M (in)"
        label in2 "PMIC-2 ASIC 1.8V_MAIN Rail (out1)"
        label in3 "PMIC-2 ASIC 1.2V_MAIN Rail (out2)"
